{
  "identifier": "notification-window",
  "description": "Permissions for the custom ClipBridge notification popup window",
  "windows": ["clipnotif"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-set-size",
    "shell:allow-open"
  ]
}
