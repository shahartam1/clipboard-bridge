<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Paired Devices" android:textSize="18sp" android:textStyle="bold"
            android:layout_marginBottom="12dp" />
        <TextView android:id="@+id/emptyText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No devices paired yet. Use the Pair tab." android:visibility="visible" />
        <LinearLayout android:id="@+id/peerList"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gap="8dp" />
    </LinearLayout>
</ScrollView>
